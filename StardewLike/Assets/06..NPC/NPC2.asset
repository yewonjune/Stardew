  npcData: {fileID: 11400000, guid: 29040cf6fc73d5a43bced706b55ab2e6, type: 2}
  sequences:
  - lines:
    - text: "\uC624\uB298\uC740 \uCEE4\uD53C \uC9C4\uD558\uAC8C \uB0B4\uB838\uC5B4."
      emotion: 0
    - text: "\uB108 \uD53C\uACE4\uD574 \uBCF4\uC774\uAE38\uB798, \uC11C\uBE44\uC2A4\uB85C
        \uC0F7 \uD558\uB098 \uB354 \uB123\uC5B4\uC904\uAE4C?"
      emotion: 1
  - lines:
    - text: "\uC2E0\uBA54\uB274 \uB098\uC654\uC5B4. \uADFC\uB370 \uC194\uC9C1\uD788
        \uB09C \uBCC4\uB85C\uB354\uB77C."
      emotion: 2
    - text: "\uADF8\uB798\uB3C4 \uB124 \uCDE8\uD5A5\uC77C\uC9C0\uB3C4 \uBAA8\uB974\uB2C8\uAE4C
        \uD55C\uBC88 \uB9C8\uC154\uBCFC\uB798?"
      emotion: 0
  - lines:
    - text: "\uC654\uC5B4?"
      emotion: 3
    - text: "\uC77C\uB2E8 \uC549\uC544, \uBB50 \uB9C8\uC2E4\uC9C0 \uC0DD\uAC01\uD574"
      emotion: 0
